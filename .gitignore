# 敏感配置与密钥（切勿提交）
openclaw.json
openclaw.json.bak
openclaw.json.bak.*
*.local.json
.env
.env.*
!.env.example

# 身份与设备（含私钥、token）
identity/
devices/
credentials/

# 运行时与会话（含 token、会话内容）
agents/
logs/
delivery-queue/
media/
cron/
update-check.json

# 备份与缓存
backup/
*.bak
.cache/

# 工作区：先忽略全部，再放开要推送的（避免嵌套 .git 被加入）
workspace/*
workspace/.git/
workspace/.openclaw/
workspace/node_modules/
workspace/2026-02-19-tankbattle/
# 放开 workspace 根下 8 个文档与 3 个文件
!workspace/ROLES.md
!workspace/AGENTS.md
!workspace/TOOLS.md
!workspace/BOOTSTRAP.md
!workspace/USER.md
!workspace/IDENTITY.md
!workspace/SOUL.md
!workspace/HEARTBEAT.md
!workspace/install-gh.sh
!workspace/package.json
!workspace/.gitignore
# 放开 four-roles-core（流程/角色/文档），不推送运行时
!workspace/four-roles-core/
workspace/four-roles-core/context.json
workspace/four-roles-core/runs/

# 浏览器配置/用户数据
browser/openclaw/

# 通用
node_modules/
.DS_Store
*.log
Thumbs.db
